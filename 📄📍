<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>كلماتنا ولا كلماتك</title>

<link rel="stylesheet" href="style.css">
</head>

<body>

<header>
🎵 كلماتنا ولا كلماتك 🎵
</header>

<div class="container">

<div class="box">

<h2>اختر دورك</h2>

<select id="role">
<option>كاتب ✍️</option>
<option>حاكم ⚖️</option>
</select>


<h2>اكتب كلماتك</h2>

<textarea id="words" placeholder="اكتب كلمات الأغنية هنا..."></textarea>

<button onclick="saveWords()">حفظ المشاركة</button>

</div>


<div class="box">

<h2>المشاركات</h2>

<div id="list"></div>

</div>

</div>


<script src="script.js"></script>

</body>
</html>body{
    background:#111;
    color:white;
    font-family:Tahoma, Arial;
    margin:0;
    text-align:center;
}


header{
    background:#5b0015;
    color:#d4af37;
    padding:25px;
    font-size:32px;
    font-weight:bold;
}


.container{
    padding:20px;
}


.box{
    background:#222;
    border:2px solid #d4af37;
    border-radius:15px;
    max-width:600px;
    margin:20px auto;
    padding:20px;
}


textarea{

width:90%;
height:150px;

background:#111;
color:white;

border:1px solid #d4af37;
border-radius:10px;

padding:10px;

font-size:16px;

}


select{

padding:10px;
background:#111;
color:white;
border:1px solid #d4af37;

}


button{

background:#d4af37;
color:#111;

border:0;

padding:12px 30px;

margin-top:15px;

border-radius:10px;

font-size:17px;

cursor:pointer;

}


.card{

background:#333;

margin:10px;

padding:15px;

border-radius:10px;

border-right:5px solid #d4af37;
}let songs = JSON.parse(localStorage.getItem("songs")) || [];


function saveWords(){

let words = document.getElementById("words").value;
let role = document.getElementById("role").value;


if(words.trim()==""){

alert("اكتب كلماتك أولاً");

return;

}


let song = {

role: role,

words: words,

date: new Date().toLocaleDateString()

};


songs.push(song);


localStorage.setItem(
"songs",
JSON.stringify(songs)
);


document.getElementById("words").value="";


showSongs();


alert("تم حفظ مشاركتك 🎉");

}



function showSongs(){

let list=document.getElementById("list");

list.innerHTML="";


songs.forEach(song=>{


list.innerHTML += `

<div class="card">

<h3>${song.role}</h3>

<p>${song.words}</p>

small>📅 ${song.date}</small>

</div>

`;


});


}


showSongs();
